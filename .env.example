# ── IzdeMe v2 environment (copy to .env.local) ─────────────────────────────
# NOTE: nothing here is required for the Phase 0/3 foundation (schemas, migrations,
# deterministic Fit Score + parser, unit tests). These are wired in later phases.

# --- Supabase (Phase 1: auth + persistence) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only; used by the Job Ingestion Service to write vacancies

# --- LLM providers (Phase 4: parser / planner / ranker / tailor agents) ---
# Provider-agnostic, mirrors v1. Groq's llama-3.3-70b-versatile was DEPRECATED
# (17 Jun 2026) — pin a live model and verify on console.groq.com/docs/models.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LLM_PROVIDER=groq
LLM_LOCK=groq

# --- Embeddings (Phase 2: pgvector retrieval) ---
# gemini-embedding-001 truncated to 1536 dims (Matryoshka), asymmetric task types.
GEMINI_EMBED_MODEL=gemini-embedding-001
EMBED_DIMS=1536

# --- HeadHunter (unchanged from v1: OAuth client_credentials, area=40) ---
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_ACCESS_TOKEN=
HH_USER_AGENT=IzdeMe-JobAgent/2.0 (murat.askarov@nu.edu.kz)
HH_AREA=40
HH_HOST=hh.kz

# --- Background jobs / cache (Phases 5, 7) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
